<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Todo List</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
  </head>
  <body class="min-h-screen bg-zinc-50 text-zinc-950">
    <main
      class="mx-auto flex min-h-screen w-full max-w-xl flex-col justify-center px-5 py-10"
    >
      <section
        class="w-full rounded-lg border border-zinc-200 bg-white p-5 shadow-sm"
      >
        <h1 class="text-2xl font-semibold">Todo List</h1>

        <form id="todoForm" class="mt-5 flex gap-2">
          <input
            id="newtask"
            type="text"
            name="task"
            placeholder="Add a task"
            class="min-w-0 flex-1 rounded-md border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-zinc-900 focus:ring-2 focus:ring-zinc-200"
          />
          <button
            type="submit"
            class="rounded-md bg-zinc-950 px-4 py-2 text-sm font-medium text-white transition hover:bg-zinc-800"
          >
            Add task
          </button>
        </form>

        <div class="mt-6">
          <h2
            class="text-sm font-semibold uppercase tracking-wide text-zinc-500"
          >
            Pending todos
          </h2>
          <ul id="todoList" class="mt-3 space-y-3">
            <li
              class="rounded-md border border-zinc-200 px-3 py-2 text-sm text-zinc-500"
            >
              Loading todos...
            </li>
          </ul>
        </div>

        <div class="mt-6">
          <h2
            class="text-sm font-semibold uppercase tracking-wide text-zinc-500"
          >
            Completed todos
          </h2>
          <ul id="completedTodoList" class="mt-3 space-y-3">
            <li
              class="rounded-md border border-zinc-200 px-3 py-2 text-sm text-zinc-500"
            >
              Loading completed todos...
            </li>
          </ul>
        </div>
      </section>
    </main>

    <script>
      const socket = io();
      const todoForm = document.getElementById("todoForm");
      const taskInput = document.getElementById("newtask");
      const todoList = document.getElementById("todoList");
      const completedTodoList = document.getElementById("completedTodoList");

      socket.on("connect", () => {
        socket.emit("fetchTodos");
      });

      socket.on("todos_updated", (data) => {
        if (data.status === "success") {
          updateTodoLists(data.data);
        } else {
          console.log("Error");
        }
      });

      function renderEmptyState(list, message) {
        list.innerHTML = `
          <li class="rounded-md border border-zinc-200 px-3 py-2 text-sm text-zinc-500">
            ${message}
          </li>
        `;
      }

      function updateTodoLists(todos) {
        renderPendingTodos(todos.pending);
        renderCompletedTodos(todos.completed);
      }

      function renderTodoText(todo, isCompleted) {
        const titleClass = isCompleted
          ? "text-sm font-medium text-zinc-500 line-through"
          : "text-sm font-medium text-zinc-900";
        const deadline = todo.deadLine || "No deadline";

        return `
          <div class="min-w-0 flex-1">
            <p class="${titleClass}">${todo.task}</p>
            <p class="mt-0.5 text-xs text-zinc-500">Deadline: ${deadline}</p>
          </div>
        `;
      }

      function renderDeleteButton(todoId) {
        return `
          <button
            type="button"
            data-id="${todoId}"
            aria-label="Delete todo"
            title="Delete todo"
            class="delete-todo inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md text-zinc-500 transition hover:bg-red-50 hover:text-red-600"
          >
            <svg aria-hidden="true" class="h-4 w-4 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 6h18"></path>
              <path d="M8 6V4h8v2"></path>
              <path d="M19 6l-1 14H6L5 6"></path>
              <path d="M10 11v5"></path>
              <path d="M14 11v5"></path>
            </svg>
          </button>
        `;
      }

      function renderPendingTodos(todos) {
        todoList.innerHTML = "";

        if (!todos.length) {
          renderEmptyState(todoList, "No pending todos.");
          return;
        }

        todos.forEach((todo) => {
          const listItem = document.createElement("li");
          listItem.innerHTML = `
            <div class="flex items-center gap-3 rounded-md border border-zinc-200 px-3 py-2">
              <input
                type="checkbox"
                data-id="${todo._id}"
                aria-label="Mark ${todo.task} as completed"
                class="todo-checkbox h-4 w-4 shrink-0 rounded border-zinc-300 text-zinc-950 focus:ring-zinc-900"
              >
              ${renderTodoText(todo, false)}
              ${renderDeleteButton(todo._id)}
            </div>
          `;

          todoList.appendChild(listItem);
        });
      }

      function renderCompletedTodos(todos) {
        completedTodoList.innerHTML = "";

        if (!todos.length) {
          renderEmptyState(completedTodoList, "No completed todos.");
          return;
        }

        todos.forEach((todo) => {
          const listItem = document.createElement("li");
          listItem.innerHTML = `
            <div class="flex items-center gap-3 rounded-md border border-zinc-200 bg-zinc-50 px-3 py-2">
              <input
                type="checkbox"
                checked
                disabled
                aria-label="${todo.task} is completed"
                class="h-4 w-4 shrink-0 rounded border-zinc-300 text-zinc-950 focus:ring-zinc-900"
              >
              ${renderTodoText(todo, true)}
              ${renderDeleteButton(todo._id)}
            </div>
          `;

          completedTodoList.appendChild(listItem);
        });
      }

      todoList.addEventListener("change", (event) => {
        if (!event.target.classList.contains("todo-checkbox")) return;

        socket.emit("updateTodoStatus", {
          id: event.target.dataset.id,
          status: "completed",
        });
      });

      document.addEventListener("click", (event) => {
        const deleteButton = event.target.closest(".delete-todo");
        if (!deleteButton) return;

        socket.emit("deleteTodo", {
          id: deleteButton.dataset.id,
        });
      });

      todoForm.addEventListener("submit", (event) => {
        event.preventDefault();

        const task = taskInput.value.trim();
        if (!task) return;

        socket.emit("addTodo", {
          task: task,
          deadLine: new Date().toLocaleDateString(),
          status: "pending",
        });

        taskInput.value = "";
      });
    </script>
  </body>
</html>
